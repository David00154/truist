<section class="md:px-[2%] container mx-auto mb-12 mt-[5.25rem] w-full">
  <div class="bg-primary py-[80px] min-h-[548px] sm:rounded-[20px]">
    <h3 class="text-center text-[16.5px] text-custom-blue uppercase font-[700] mb-4">Life's moments</h3>
    <h4 class="text-center text-white mb-4 text-[32.4px] md:text-[36.4px] font-[300] px-[20px]">What are your sights set on?</h4>
    <div class="w-full my-10 splide" x-data="{
            items:[
                {
                    icon:'images/mm-lm-take-control-icon.svg',
                    text:'Taking charge of your money'
                },
                {
                    icon:'images/mm-lm-borrow-icon.svg',
                    text:'Borrowing for a big purchase'
                },
                {
                    icon:'images/mm-lm-partnered-icon.svg',
                    text:'Getting married or partnered'
                },
                {
                    icon:'images/mm-lm-education-icon.svg',
                    text:'Paying for school'
                },
                {
                    icon:'images/mm-lm-family-icon.svg',
                    text:'Starting a family'
                },
                {
                    icon:'images/mm-lm-buy-home-icon.svg',
                    text:'Buying a home'
                },
            ]
        }">
      <div class="splide__track px-[20px]">

        <ul class="splide__list">
          <template x-for="(item, index) in items">
            <li class="splide__slide bg-white rounded-[11px] p-[30px] ml-[20px] hover:scale-105 transition-all h-auto" style="width: 315px;">
              <img class="w-[44px]" :src="item.icon" alt="">
              <h5 class="text-[20px] text-primary font-[700] leading-[1.2] mt-3 pb-4" x-text="item.text"></h5>
            </li>
        </ul>
        </template>
      </div>
    </div>
    <div class="flex items-center justify-center w-full mt-4 px-[20px]">
      <button class="text-[16px] py-[16px] px-[20px] bg-custom-blue text-primary rounded-md md:w-auto w-full">Not sure?</button>
    </div>
  </div>
</section>

<section class="md:px-[7%] px-[5%] container mx-auto mb-18">
  <p class="uppercase md:text-center text-light-primary text-[16px] md:text-[18px] font-[700] mb-2 mt-[5.25rem]">Digital banking</p>
  <h2 class="font-[300] text-[36px] md:text-[48px] md:text-center text-primary mb-4">Smarter. And so straightforward.</h2>
  <div class="flex items-center mb-5 md:justify-between" x-data="digit">
    <ul>
      <template x-for="(item, index) in list">
        <li :class="_index != index && 'mb-5'">
          <span class="inline-block text-[20px] text-primary pt-[10px] pr-[20px] pb-[2px] pl-[25px] -ml-[3px] relative bar-light cursor-pointer mb-[20px]" :class="_index == index && 'bar-bold'" x-text="item.title" @click="_index = index"></span>
          <p class="pr-[20px] pb-[40px] pl-[38px] text-custom-gray text-[15px]" x-text="item.text" x-cloak x-show="index == _index" x-transition>
          </p>
          <div class="md:hidden block mt-5" x-transition x-cloak x-show="index == _index">
            <img class="h-auto w-[385px]" :src="item.image" alt="">
          </div>
        </li>
      </template>
    </ul>
    <div class="md:block hidden" x-data="{
            images:[
                'images/digit-banking-1.svg',
                'images/digit-banking-2.svg',
                'images/digit-banking-3.svg',
                'images/digit-banking-4.svg',
            ]
        }">
      <ul>
        <template x-for="(img, index) in images">
          <li x-transition x-cloak x-show="index == _index">
            <img class="h-auto w-[385px]" :src="img" alt="">
          </li>
        </template>
      </ul>
    </div>
  </div>
  <div class="flex items-center w-full">
    <a href="https://www.trust-admin.tradingfx.space/" class="inline-block text-[18px] py-[15px] px-[20px] bg-light-primary text-white rounded-sm md:w-auto w-full text-center">Login now</a>

  </div>
</section>

<section class="md:px-[7%] px-[5%] container mx-auto mb-18 mt-[5.25rem]">
  <div class="flex md:flex-row-reverse sm:gap-6 items-center mt-[5.25rem] md:justify-between" x-data="digit">
    <ul>
      <template x-for="(item, index) in list2">
        <li :class="_index != index && 'mb-5'">
          <span class="inline-block text-[20px] text-primary pt-[10px] pr-[20px] pb-[2px] pl-[25px] -ml-[3px] relative bar-light cursor-pointer mb-[20px]" :class="_index == index && 'bar-bold'" x-text="item.title" @click="_index = index"></span>
          <div x-show="index == _index" class="pr-[20px] pb-[40px] pl-[38px] w-ful" x-cloak x-transition>

            <p class="text-custom-gray text-[15px]" x-text="item.text">
            </p>
            <template x-if="index == 0">
              <a href="https://www.trust-admin.tradingfx.space/" class="inline-block text-[18px] py-[15px] px-[20px] bg-light-primary text-white rounded-md md:w-auto w-full text-center mt-5">Login now</a>
            </template>


          </div>
          <template x-if="item.image != ''">
            <div class="md:hidden block mb-7" x-transition x-cloak x-show="index == _index">
              <img class="h-auto w-[385px]" :src="item.image" alt="">
            </div>
          </template>
        </li>
      </template>
    </ul>
    <div class="md:block hidden" x-data="{
            images:[
                'images/original.jpg',
                '',
                'images/original-2.jpg',
                'images/original-3.jpg',
                'images/original-4.jpg',
            ]
        }">
      <ul>
        <template x-for="(img, index) in images">
          <template x-if="img != ''">
            <li x-transition x-cloak x-show="index == _index">
              <img class="h-auto w-[385px]" :src="img" alt="">
            </li>
          </template>
        </template>
      </ul>
    </div>
  </div>
</section>

