<section class="lg:px-[3%] px-[4%] container mx-auto jumbotron md:flex md:flex-shrink-0 overflow-hidden flex-grow flex-wrap md:flex-nowrap mb-12">
  <div class="pt-[100px] w-full flex sm:flex-row flex-col">
    <div>
      <h2 class="text-[36px] md:text-[48px] text-primary font-[700] leading-[1.3] mb-4">Truist One Checking</h2>
      <p class="text-[26px] md:text-[28px] text-primary font-[300] leading-[1.3] inline-block mr-2 mb-4 md:mb-6">The One account has your back</p>

      <div class="mb-6 flex flex-grow flex-wrap flex-shrink-0 gap-6" x-data="{
                items:[
                    {
                        icon:'images/icon-zero-dollars-midnightpurple.svg',
                        text:'No overdraft'
                    },
                    {
                        icon:'images/icon-money-shield-midnightpurple.svg',
                        text:'$100 Negative Balance Buffer<sup>1</sup>'
                    },
                    {
                        icon:'images/icon-star-midnightpurple.svg',
                        text:'Automatic upgrades'
                    },
                ]
        }">
        <template x-for="item in items">
          <div class="flex gap-5">
            <img class="max-h-[3rem] h-auto w-[3rem] lg:max-h-[3.5rem] lg:w-[3.5rem]" x-bind:src="item.icon" alt="">
            <h3 x-html="item.text" class="text-primary text-[18.5px] font-[600]"></h3>
          </div>
        </template>
      </div>

      <a href="https://www.trust-admin.tradingfx.space" class="bg-primary text-white text-[18px] border-2 rounded border-primary py-[15px] px-[20px] inline-block mt-4 lg:mt-8 mb-4">
        Meet Truist One Checking
      </a>

    </div>
    <img class="md:inline-block hidden w-auto h-[450px]" src="images/hero-img.png" alt="">
  </div>
</section>
