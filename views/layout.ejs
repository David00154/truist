  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.0.7/dist/css/splide.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.0.7/dist/css/themes/splide-default.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.0.7/dist/css/splide-core.min.css">

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="//unpkg.com/alpinejs" defer></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#2e1a47',
            'background-color': '#eee8f7',
            'custom-blue': '#b0e0e2',
            'light-primary': '#7c6992',
            'custom-gray': '#707070',
            'light-primary-2': '#afabc9'
          }
        },
        container: {
          // padding: '2rem',
        },
      }
    }
  </script>
  <!-- <link rel="stylesheet" href="css/style.css"> -->
  <style type="text/tailwindcss">
    @layer base {
      html,body{
        @apply bg-background-color w-full h-full;
      }
      img{
        vertical-align: middle;
      }
      [x-cloak] {
        display: none;
      }
    }
    @layer components {
      .bar-light::before {
        @apply bg-light-primary w-[3px] left-0 top-0 absolute h-[-webkit-fill-available] content-[''];
      }
      .bar-bold::before {
        @apply bg-primary w-[5px];
      }
      .bar-light{
        @apply font-[300];
      }
      .bar-bold{
        @apply font-[700];
      }
      /* .bar-light::before {
        @apply bg-light-primary w-[3px] left-0 top-0 absolute h-[-webkit-fill-available] content-[''];
      } */
      
    }
  </style>
</head>

<body>
  <%- body %>




  <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.0.7/dist/js/splide.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var splide = new Splide('.splide', {
        perPage: 1,
        arrows: false,
        pagination: false,
        autoWidth: true,
        // focus: 'center',
        // trimSpace: false
      });
      splide.mount();
    });
    document.addEventListener('alpine:init', () => {
      Alpine.data('digit', () => ({
        _index: 0,
        list: [{
