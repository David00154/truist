<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Truist | Personal Banking, Commercial Banking, Mortgages, Investments</title>
  <link rel="icon" href="images/favicon.png" type="image/png">

  <link rel="prefetch" href="fonts/icomoon.ttf" as="font/woff2" crossorigin="anonymous">
  <link rel="prefetch" href="fonts/icomoon.woff" as="font/woff2" crossorigin="anonymous">
  <link rel="prefetch" href="fonts/truist-icons.eot" as=" font/woff2" crossorigin="anonymous">
